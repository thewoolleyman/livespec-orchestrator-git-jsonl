// Project-local livespec configuration for livespec-orchestrator-git-jsonl.
// This plugin dogfoods livespec: the SPECIFICATION/ tree at the repo
// root is the live spec. As of epic li-ws2iv4 (Phase 5 cutover), this
// repo's OWN impl tracking lives in the per-repo livespec-orchestrator-beads-fabro
// Dolt tenant; the legacy plaintext work-items JSONL ledger was
// frozen under archive/.
//
// Authority: livespec/SPECIFICATION/contracts.md
//   §"Cross-repo coordination — pin-and-bump"
//   §"`compat` block" (the schema this file populates)
{
  "template": "livespec",
  "spec_root": "SPECIFICATION",
  "implementation": { "plugin": "livespec-orchestrator-beads-fabro" },
  // Fleet-default credential-injection wrapper (argv-form command prefix) for
  // this repo's OWN work-item tracking. The livespec-orchestrator-beads-fabro
  // impl-plugin CLIs (see "implementation" above) run against this repo's Dolt
  // tenant and re-exec through this prefix when BEADS_DOLT_PASSWORD is absent,
  // so the 1Password Environment wrapper injects the shared fleet tenant secret
  // before any beads CLI runs. The git-jsonl plugin's OWN shipped CLIs read a
  // local JSONL store and need no injected secret, so they do NOT consume this
  // key. Backend-agnostic per livespec core's config schema (a non-empty array
  // of strings); the secret backend + injected vars are this project's own
  // concern and are NEVER committed here.
  "credential_wrapper": ["/usr/local/bin/with-livespec-env.sh", "--"],
  "harnesses": {
    "claude": { "status": "supported", "canonical_command": "livespec-orchestrator-git-jsonl:next" },
    "codex":  { "status": "supported", "canonical_command": "livespec-orchestrator-git-jsonl:next" }
  },
  "livespec-orchestrator-beads-fabro": {
    "format": "beads",
    "compat": { "livespec": ">=0.1.0,<1.0.0", "pinned": "v0.18.4" },
    // Per-repo beads tenant CONNECTION block. tenant==database==server_user is the
    // load-bearing tenant identity (one Dolt name serves all three). The issue-ID
    // `prefix` is bd's short server-stored create-prefix (`bd-gj`), DECOUPLED from
    // the DB name. Tenant PASSWORD deliberately ABSENT — supplied only via the
    // BEADS_DOLT_PASSWORD env var at bd-call time, never committed. TCP-only, so no `socket` key.
    "connection": {
      "tenant": "livespec-orchestrator-git-jsonl",
      "prefix": "bd-gj",
      "database": "livespec-orchestrator-git-jsonl",
      "server_user": "livespec-orchestrator-git-jsonl",
      "server_host": "127.0.0.1",
      "server_port": 3307,
      "fake": false
    },
    // Autonomous-mode levers (maintainer-directed 2026-07-20). Two of the three
    // policy settings in livespec/SPECIFICATION/contracts.md §"The three policy
    // settings" are moved off their safe defaults so ready work is ADMITTED and
    // ACCEPTED without a human valve:
    //   auto_approve_ready: true      — pending-approval → ready with no human.
    //   acceptance_mode: "ai-only"    — post-merge acceptance without a human.
    // The third lever, `merge_on_review_cap`, deliberately STAYS at its safe
    // `false` default and is NOT listed here: a review that cannot converge
    // within `review_fix_cap` rounds is precisely the case that must reach a
    // human, per the design record cited in that section. A design-human-gated
    // (spec-change-tier) item still cannot auto-approve regardless of these.
    //
    // EDIT THIS BLOCK BY HAND. Do NOT use `drive --action set-config:<k>:<v>`:
    // that surface round-trips the file through json.dumps and silently strips
    // every comment here while reporting green — tracked as bd-ib-lmi5.
    "dispatcher": {
      "auto_approve_ready": true,
      "acceptance_mode": "ai-only"
    }
  }
}
